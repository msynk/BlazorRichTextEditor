@page "/"

<PageTitle>BlazorRichTextEditor - Overview</PageTitle>

<div class="page">
    <section class="hero">
        <span class="eyebrow">✦ Native Blazor component</span>
        <h1>A rich text editor that drops straight into your Blazor app</h1>
        <p>WYSIWYG editing two-way bound to an HTML or Markdown string. All component logic lives in C# with a
            deliberately thin JavaScript bridge for the browser-only concerns.</p>
        <div class="cta">
            <a class="btn btn-primary" href="/getting-started">Get started</a>
            <a class="btn btn-ghost" href="/toolbar">Explore the toolbar</a>
        </div>
        <div class="badge-row">
            <span class="badge">@@bind-Value</span>
            <span class="badge">HTML &amp; Markdown</span>
            <span class="badge">Tables &amp; media</span>
            <span class="badge">EditForm</span>
            <span class="badge">Dark mode &amp; RTL</span>
        </div>
    </section>

    <section>
        <h2>Try it</h2>
        <p>The editor below uses the full extended toolbar. Type, paste, format, and drop in an image -
            the bound value and rendered output update live.</p>

        <div class="demo-box">
            <BlazorRichTextEditor @bind-Value="_html"
                                  Toolbar="BlazorRichTextEditorToolbar.AllExtended"
                                  ShowCount="true"
                                  Placeholder="Start writing - try images, tables, color, source view, find & replace..."
                                  Height="240px" />
        </div>

        <div class="row">
            <div class="col">
                <h3>Bound value (<code class="inline">@@bind-Value</code>)</h3>
                <pre class="code">@_html</pre>
            </div>
            <div class="col">
                <h3>Rendered output</h3>
                <div class="preview">@((MarkupString)_html)</div>
            </div>
        </div>
    </section>

    <section>
        <h2>What's in the box</h2>
        <div class="feature-grid">
            <div class="feature-card">
                <div class="ic">𝐁</div>
                <h3>Formatting</h3>
                <p>Bold, italic, headings, lists, blockquote, code, alignment, indent, sub/superscript, undo/redo.</p>
            </div>
            <div class="feature-card">
                <div class="ic">🖼️</div>
                <h3>Rich content</h3>
                <p>Links, images (URL, drag-drop, paste, upload, resize), tables, media embeds, and rules.</p>
            </div>
            <div class="feature-card">
                <div class="ic">🎨</div>
                <h3>Color &amp; type</h3>
                <p>Text and highlight color, plus configurable font family and size pickers.</p>
            </div>
            <div class="feature-card">
                <div class="ic">⚡</div>
                <h3>Productivity</h3>
                <p>Markdown shortcuts, a slash menu, emoji picker, find &amp; replace, and full-screen mode.</p>
            </div>
            <div class="feature-card">
                <div class="ic">🛡️</div>
                <h3>Output &amp; safety</h3>
                <p>HTML or Markdown output, an HTML source view, and allowlist sanitization.</p>
            </div>
            <div class="feature-card">
                <div class="ic">🧩</div>
                <h3>Integration</h3>
                <p>EditForm validation, character/word count, theming + dark mode, RTL/i18n, imperative API.</p>
            </div>
        </div>
        <p class="mt">Use the navigation on the left to explore each capability with live demos and copy-paste sample code.</p>
    </section>

    <section>
        <h2>Install &amp; set up</h2>
        <p>Reference the <code class="inline">BlazorRichTextEditor</code> package, add the stylesheet to your
            host page, and use the component inside an interactive render mode.</p>

        <CodeSample Title="App.razor (host)" Code="@_setupHost" />
        <CodeSample Title="Razor (usage)" Code="@_setupUsage" />

        <div class="note">
            The component needs an <strong>interactive</strong> render mode (Server or WebAssembly) because it
            relies on JS interop for <code>contenteditable</code>, selection, and formatting commands.
        </div>
    </section>
</div>

@code {
    private string _html = "<h2>Welcome 👋</h2><p>This editor is <strong>bound</strong> to a C# string. " +
        "Edit me, then watch the HTML update.</p><ul><li>Bullet and numbered lists</li>" +
        "<li>Headings, quotes, code blocks</li><li>Links, alignment, undo/redo</li></ul>";

    private const string _setupHost = @"<link rel=""stylesheet""
      href=""_content/BlazorRichTextEditor/blazorRichTextEditor.css"" />";

    private const string _setupUsage = @"@using BlazorRichTextEditor

<BlazorRichTextEditor @bind-Value=""html"" Placeholder=""Write something..."" />

@code {
    private string html = ""<p>Hello <strong>world</strong>.</p>"";
}";
}
